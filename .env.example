# ─── AI Provider Selection ────────────────────────────────────────────────────
# Choose: "groq" (RECOMMENDED - free, fast, 128k context), "github" (8k limit), or "watsonx"
AI_PROVIDER=groq

# ─── Groq (RECOMMENDED - FREE, fast, large context window) ───────────────────
# Get free API key at: https://console.groq.com/keys
# No credit card required! 128k context window, very fast inference
GROQ_API_KEY=

# ─── GitHub Models (FREE but 8k token limit) ──────────────────────────────────
# Uses your existing GitHub token for authentication
# Get token at: https://github.com/settings/tokens
# Required scopes: repo (for PR creation), public_repo (for public repos)
GITHUB_TOKEN=

# ─── IBM watsonx.ai (alternative provider - requires credit card) ─────────────
# Only needed if AI_PROVIDER=watsonx
# Get these from: https://cloud.ibm.com/resources → watsonx.ai instance
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ─── App Configuration ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Demo Mode ───────────────────────────────────────────────────────────────
# Set to "true" to return pre-cached django/django output instantly.
# Bypasses the live watsonx.ai pipeline. Used for reliable demo recording.
DEMO_MODE=false